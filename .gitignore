# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
out/
*.tsbuildinfo
.turbo/

# Tauri / Rust
target/
**/src-tauri/target/
**/src-tauri/gen/

# Env & secrets — NEVER commit
.env
.env.*
!.env.example
*.local

# Local Relavium state (run history, keys live in the OS keychain, never here).
# Ignore SQLite databases by extension so a stray/encrypted db (any name/dir) is never
# committable — the tracked migrations under packages/db/drizzle are *.sql, not *.db.
.relavium/
*.db
*.sqlite
*.sqlite3
*.db-wal
*.db-shm

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Test / coverage
coverage/
.vitest/

# Claude Code transient state (skills/agents ARE committed; runtime locks are not)
.claude/scheduled_tasks.lock
.claude/**/*.lock
