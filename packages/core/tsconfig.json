{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // The default typecheck + the ESLint project-service config — it covers the WHOLE package,
    // INCLUDING the `*.test.ts` files (which import `vitest`, transitively pulling in `@types/node`;
    // e.g. sandbox.perf.test.ts legitimately reads `process.memoryUsage()`). So `types: ["node"]`
    // here. No emit — rootDir/outDir live in tsconfig.build.json.
    //
    // The platform-free GUARD (CLAUDE.md rule 5 — the engine runs identically in Node, the Tauri
    // WebView, the VS Code host, and Bun) is a SEPARATE run: tsconfig.purity.json (`types: []`, tests
    // excluded), invoked alongside this by the `typecheck` script. It MUST be separate: including the
    // tests here pulls `@types/node` into the program, so a single `types: []` config would silently
    // typecheck a stray `process`/`Buffer`/`node:*` in SHIPPING source as clean. Mirrors
    // @relavium/llm's tsconfig.json / tsconfig.seam.json split.
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}
