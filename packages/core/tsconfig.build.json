{
  // Extends the PURITY gate (not tsconfig.json), so the emitted engine is built with `types: []` —
  // no Node/DOM types reach shipping `dist`. Tests are already excluded by tsconfig.purity.json.
  "extends": "./tsconfig.purity.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "src",
    "outDir": "dist",
    "incremental": true,
    "declarationMap": false,
    "sourceMap": false
  },
  "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts"]
}
