{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // The default typecheck + the ESLint project-service config. It covers the WHOLE package — the
    // seam and the platform-coupled `src/adapters/**` (provider SDKs) and `src/conformance/**` (the
    // SDK-driven harness) — so `types: ["node"]` is on (the SDKs reference Node globals like
    // `AbortSignal`). The platform-free GUARD on the seam is a separate run: tsconfig.seam.json
    // (`types: []`, those zones excluded), invoked by the `typecheck` script. No emit here —
    // rootDir/outDir live in tsconfig.build.json.
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}
