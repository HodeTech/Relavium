{
  // Builds the whole package (seam + adapters + conformance) with Node types available, so the
  // adapters compile. The platform-free guard on the seam is tsconfig.seam.json (`types: []`), run
  // separately by `typecheck`.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "src",
    "outDir": "dist",
    "incremental": true,
    "declarationMap": false,
    "sourceMap": false
  },
  "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts", "src/conformance/**"]
}
