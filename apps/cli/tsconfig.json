{
  // apps/cli is a Node app (NOT an engine package): it legitimately uses node:* APIs, so
  // `types: ["node"]` here and no platform-purity gate (that guard is the engine's, ADR-0003).
  // tsup owns the build; this config is typecheck-only (`tsc --noEmit`).
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"],
    // The `ink` TUI renderer (2.E, ADR-0047) is the surface's only React/JSX consumer — confined to
    // src/render/tui/. The automatic runtime needs no per-file `import React` (tsc injects react/jsx-runtime).
    "jsx": "react-jsx"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
